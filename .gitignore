## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache and settings
.vs/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Whisper Models (They are large and downloaded automatically)
WhisperOpenVINO.Api/bin/**/Models/
WhisperOpenVINO.Api/Models/
*.bin
*.xml

# FFmpeg Executables (Downloaded automatically)
ffmpeg.exe
ffprobe.exe
ffmpeg
ffprobe

# OS files
.DS_Store
Thumbs.db
